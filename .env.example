# Copy this file to .env and fill in your own Supabase project credentials.
# Get these values from: https://supabase.com/dashboard/project/_/settings/api

# Your Supabase project URL (e.g. https://abcdefghijk.supabase.co)
VITE_SUPABASE_URL=

# Public "anon" / publishable key. Safe to expose in the browser
# because Row-Level Security policies guard every table.
VITE_SUPABASE_PUBLISHABLE_KEY=

# Project reference (the subdomain part of your Supabase URL).
VITE_SUPABASE_PROJECT_ID=
